# ════════════════════════════════════════════
#  Balaji Fleet Tracker — Root Environment
#  Copy to .env and fill in your values
# ════════════════════════════════════════════

# ── Backend ──────────────────────────────────
NODE_ENV=production
PORT=3001

# JWT — MUST be changed before deployment
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=24h

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@Balaji2024
ADMIN_NAME=Balaji Fleet Admin

# CORS — set to your actual domain
CORS_ORIGIN=https://your-domain.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Frontend (build args) ─────────────────────
VITE_API_URL=https://your-domain.com
VITE_SOCKET_URL=https://your-domain.com
VITE_APP_NAME=Balaji Fleet Tracker
VITE_COMPANY_NAME=Balaji Readymix

# OpenStreetMap tile — free, no API key
VITE_TILE_URL=https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png
VITE_TILE_ATTRIBUTION=&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>
