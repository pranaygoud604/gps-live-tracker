# Backend connection — no paid services needed
VITE_API_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001

# App branding
VITE_APP_NAME=Balaji Fleet Tracker
VITE_COMPANY_NAME=Balaji Readymix

# OpenStreetMap tiles — free, no API key required
# Default: https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
# Optional free alternatives:
#   CartoDB Dark: https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png
#   Stamen Toner: https://stamen-tiles-{s}.a.ssl.fastly.net/toner/{z}/{x}/{y}{r}.png
VITE_TILE_URL=https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png
VITE_TILE_ATTRIBUTION=&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>
