NODE_ENV=production
PORT=3001

# CORS - set to your frontend domain in production
CORS_ORIGIN=http://localhost:5173

# JWT - use a strong random secret in production (min 32 chars)
JWT_SECRET=change-this-to-a-strong-random-secret-at-least-32-characters-long
JWT_EXPIRES_IN=24h

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@Balaji2024
ADMIN_NAME=Balaji Fleet Admin

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
